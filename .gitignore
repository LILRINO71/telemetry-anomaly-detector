# ---------------------------------------------------------------------------
# Byte-compiled / optimized / cached Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Packaging / build artifacts
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Test / coverage / lint / type-check caches
# ---------------------------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.hypothesis/

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
notebooks/**/*.nbconvert.ipynb

# ---------------------------------------------------------------------------
# Generated pipeline artifacts (kept out of version control)
# ---------------------------------------------------------------------------
data/raw/
data/processed/
models/*.joblib
models/*.json
reports/*

# Keep curated sample data, the metrics summary, and report figures tracked so
# results are visible without retraining. The model binary stays regenerable.
!data/sample/
!models/metrics.json
!reports/*.png
!.gitkeep

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# OS cruft
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
